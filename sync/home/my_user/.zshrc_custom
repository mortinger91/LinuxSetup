### My zsh common options ###

# Setting my custom oh-my-zsh settings
ZSH_THEME="michelebira"
HYPHEN_INSENSITIVE="true"
zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 14
COMPLETION_WAITING_DOTS="true"
plugins=(git fzf-tab)
# These are no longer omz plugins since they are installed as apt packages
source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

export TIMER_THRESHOLD=2    # Only show for commands >2 seconds
export TIMER_PRECISION=1    # Show 1 decimal place

source $ZSH/oh-my-zsh.sh

export PATH=/usr/bin:/home/michele/.local/bin:/snap/bin:$PATH

# Set up fzf key bindings and fuzzy completion
eval "$(fzf --zsh)"

# --- Fuzzy `git switch <partial><Tab>` ----------------------------------
# Typing `git switch <text>` then Tab opens fzf over all branches with
# <text> prefilled as the (fuzzy) query. Anything else defers to fzf-tab.
_fzf_git_switch_widget() {
  setopt local_options extended_glob

  # Match `git [..]switch[..]<rest>` (also `sw`), cursor at end of line.
  if [[ $CURSOR == $#BUFFER && \
        $BUFFER == (#b)git[[:space:]]##(switch|sw)[[:space:]]##(*) ]]; then
    local query=$match[2]

    # Flags / branch creation -> let normal completion handle it.
    if [[ $query == -* ]]; then
      zle fzf-tab-complete
      return
    fi

    local branches selected
    branches=$(
      {
        git for-each-ref --sort=-committerdate \
            --format='%(refname:short)' refs/heads
        git for-each-ref --format='%(refname:short)' refs/remotes \
          | sed 's@^[^/]*/@@'
      } 2>/dev/null | awk '!seen[$0]++ && $0 != "HEAD"'
    )

    if [[ -n $branches ]]; then
      selected=$(print -rl -- ${(f)branches} \
        | fzf --height=50% --layout=reverse --query="$query" --select-1)
      if [[ -n $selected ]]; then
        BUFFER="git switch $selected"
        CURSOR=$#BUFFER
      fi
    fi
    zle reset-prompt
  else
    zle fzf-tab-complete
  fi
}
zle -N _fzf_git_switch_widget
bindkey '^I' _fzf_git_switch_widget

# command-status line: green ✔ on success, red ✗ code on failure + timer
zmodload zsh/datetime                    # provides $EPOCHREALTIME
autoload -Uz add-zsh-hook

_STATUS_MIN_SECONDS=3                     # only show timing above this (0 = always)

_status_fmt() {                          # 6.3 -> 6.3s ; 125.4 -> 2m5.4s
  local -F secs=$1
  local out=
  local -i h m
  (( h = secs / 3600 )); secs=$(( secs - h * 3600 ))
  (( m = secs / 60   )); secs=$(( secs - m * 60   ))
  (( h )) && out+="${h}h"
  (( m )) && out+="${m}m"
  out+="$(printf '%.1f' $secs)s"
  print -r -- $out
}

_status_preexec() { _cmd_start=$EPOCHREALTIME }

_status_precmd() {
  local code=$?                          # MUST be the first line
  RPROMPT=''                             # kill the theme's right-side exit code
  [[ -z $_cmd_start ]] && return         # bare Enter -> print nothing

  local -F elapsed=$(( EPOCHREALTIME - _cmd_start ))
  unset _cmd_start

  local parts=()
  if (( code != 0 )); then
    parts+=( "%F{red}✗ ${code} ↵%f" )
  else
    parts+=( "%F{green}✔%f" )
  fi
  (( elapsed >= _STATUS_MIN_SECONDS )) && parts+=( "%F{cyan}⏱ $(_status_fmt $elapsed)%f" )
  (( $#parts )) && print -P -- "${(j: :)parts}"
}

add-zsh-hook preexec _status_preexec
add-zsh-hook precmd  _status_precmd

# Set up zoxide smart directory navigator
eval "$(zoxide init zsh)"

# History related settings
HISTSIZE=100000
SAVEHIST=2000000
setopt HIST_REDUCE_BLANKS

export EDITOR=nano

# n: don't show line numbers, a: search is faster, s: cut blank lines
# i: no case-sensitive search, x8: tab stops to 8 spaces,
# mouse, wheel-lines: settings for mouse/trackpad scrolling
# -F (quit immediately if output fits on one screen).
# -X (--no-init) — Don't send the terminal initialization/deinitialization strings (termcap ti/te) when entering/exiting less. Practically: the screen doesn't clear when you quit less, so the output stays visible in your terminal history
# -R (--RAW-CONTROL-CHARS) — Pass ANSI color/bold/underline escape sequences through to the terminal so they render as actual colors. Other escape sequences are still shown as-is. Without this, all escape codes print literally.
export LESS='-nasix8FXR --mouse --wheel-lines=2'

export COMPILER_LAUNCHER=ccache

# Needed by ydotool to communicate with the `ydotoold` daemon
export YDOTOOL_SOCKET="/run/user/1000/.ydotool_socket"

# My zsh system-specific options:
if [ -f ~/.zshrc_custom_local ]; then
  . ~/.zshrc_custom_local
fi

# My zsh common aliases:
if [ -f ~/.zshrc_custom_aliases ]; then
  . ~/.zshrc_custom_aliases
fi
