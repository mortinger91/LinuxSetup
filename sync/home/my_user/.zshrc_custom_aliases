# INTERFACE is defined in ~/.zshrc
function whatsmyip() {
  timeout=10
  # Internal IP Lookup.
  if command -v ip >/dev/null 2>&1; then
    echo -n "Internal IP: "
    ip addr show $INTERFACE | grep "inet " | awk '{print $2}' | cut -d/ -f1
  else
    echo -n "Internal IP: "
    ifconfig $INTERFACE | grep "inet " | awk '{print $2}'
  fi
  echo ""

  # External IP Lookup
  echo -n "External IP: "
  local ip_output ip_exit_code
  ip_output=$(timeout ${timeout}s curl -s ipinfo.io 2>&1)
  ip_exit_code=$?
  if [ $ip_exit_code -eq 0 ]; then
    echo "$ip_output"
  elif [ $ip_exit_code -eq 124 ]; then
    echo "curl timeout"
  else
    echo "curl error: $ip_output"
  fi
  echo ""

  echo -n "DNS: "
  local dns_output dns_exit_code
  dns_output=$(timeout ${timeout}s nslookup google.com 2>&1)
  dns_exit_code=$?
  if [ $dns_exit_code -eq 0 ]; then
    echo "$dns_output" | grep "^Address:" | head -n 1 | awk '{print $2}'
  elif [ $dns_exit_code -eq 124 ]; then
    echo "nslookup timeout"
  else
    echo "nslookup error: $dns_output"
  fi
}
alias myip="whatsmyip"

function fzf_preview() {
  if [ $# -eq 0 ]; then
    fzf --preview "batcat --color=always --style=numbers,header --line-range=:500 {}" --preview-window wrap | xclip -selection clipboard
  elif [ $# -eq 1 ]; then
    find "$1" -type f | fzf --preview "batcat --color=always --style=numbers,header --line-range=:500 {}" --preview-window wrap | xclip -selection clipboard
  else
    echo "Error: Expected 0 or 1 arguments, got $#" >&2
    return 1
  fi
}
alias lsf='fzf_preview'

# Usage: githist DSS
# Prints all the commits that have changes containing the word.
# Of each commit only the diffs of files that contains the word are shown.
# It prints 3 lines above and below the changed line with the word
function git_history() {
  git --no-pager log -G "$1" -p --color=always | \
  awk -v term="$1" '
    BEGIN { ctx = 3; first_commit = 1; in_commit_header = 0 }

    {
      clean_line = $0
      gsub(/\033\[[0-9;]*m/, "", clean_line)

      # 1. Detect a new commit
      if (clean_line ~ /^commit [0-9a-fA-F]+/) {

        if (!first_commit) {
          # Close the previous commit body with a bottom border
          print "==========================================================="
          # Add 2 blank lines (spaces) between commits
          print ""
          print ""
        }

        first_commit = 0
        in_commit_header = 1

        # Print the commit line Bold, Yellow, and wrapped in ## FIRST
        print "\033[1;33m## " clean_line " ##\033[0m"

        # Open the commit body with a top border SECOND
        print "==========================================================="
        next
      }

      if (clean_line ~ /^diff --git/) {
        in_commit_header = 0
        header = $0
        header_printed = 0
        buf_count = 0
        after_count = 0
        next
      }

      if (in_commit_header) {
        print $0
        next
      }

      if (clean_line ~ /^@@ -/) {
        hunk = $0
        hunk_printed = 0
        next
      }

      if (clean_line ~ term && clean_line ~ /^[-+]/ && clean_line !~ /^--- / && clean_line !~ /^\+\+\+ /) {

        if (!header_printed) {
          print "\n" header
          header_printed = 1
        }

        if (!hunk_printed) {
          print hunk
          hunk_printed = 1
        }

        for (i = 0; i < buf_count; i++) {
          print buf[(buf_start + i) % ctx]
        }
        buf_count = 0

        gsub(term, "\033[1m" term "\033[22m")
        print $0

        after_count = ctx
        next
      }

      if (after_count > 0) {
        print $0
        after_count--
        next
      }

      buf[(buf_start + buf_count) % ctx] = $0
      if (buf_count < ctx) {
        buf_count++
      } else {
        buf_start = (buf_start + 1) % ctx
      }
    }

    # 2. When the script finishes, close the very last commit border
    END {
      if (!first_commit) {
        print "==========================================================="
      }
    }
  '
}
alias githist='git_history'

## Git aliases

# Rebase the current branch with origin/master
function rebaseMasterImpl() {
  currentBranch=$(git branch --show-current)
  echo "Do you want to rebase $currentBranch with current master? (y/n)"
  read -r answer
  if [[ "$answer" = "${answer#[Yy]}" ]]; then
    echo "Skipped the rebase"
    return
  fi
  # master:master should not be needed as long as the remote tracking branch
  # of local master is origin/master
  git fetch origin master:master
  git rebase master
}
alias rebasemaster="rebaseMasterImpl"

# Squash all the changes in the working directory onto the last commit
function squashImpl() {
  git commit -a --amend --no-edit
}
alias squash="squashImpl"

# Reset the local branch to the state in remote
function resethardImpl() {
  git fetch && git reset --hard origin/$(git branch --show-current)
}
alias resethard="resethardImpl"

# Force re-sign of all commits after the SHA provided
# Usage: resign 123qwdasdsad1123
function reSignImpl() {
  git rebase --force-rebase -S "$@"
}
alias resign="reSignImpl"

# Deletes the last commit and put the changes back in the working directory
function resetCommitImpl() {
  git reset --soft HEAD~1
}
alias resetcommit="resetCommitImpl"

